# Recommended: long secret for signed HttpOnly session cookies.
# Example: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-session-secret

# Required on first start: second long secret for the first-run setup.
# Example: openssl rand -base64 48
ISHIKU_SETUP_SECRET=replace-with-a-long-random-setup-secret

# Optional
TZ=Europe/Berlin
ISHIKU_LOG_LEVEL=info

# Docker Compose publishes host port 8503 to internal container port 8080.

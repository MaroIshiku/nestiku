# Nicht mit echten Werten committen.

# Pflicht: langes Zufallsgeheimnis fuer signierte Session-Cookies.
# Beispiel: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-session-secret

# Optional: Port und Bind-Adresse.
PORT=3000
BIND_IP=127.0.0.1

# ishiku Runtime-Konventionen
TZ=Europe/Berlin
ISHIKU_APP_URL=
ISHIKU_BASE_PATH=/
ISHIKU_LOG_LEVEL=info
ISHIKU_SETUP_SECRET_FILE=/run/secrets/ishiku_setup_secret

# Fallback nur fuer einfache lokale Deployments.
# Bevorzugt wird secrets/setup_secret.txt als Docker Secret.
# ISHIKU_SETUP_SECRET=replace-with-a-long-random-setup-secret

# Betrieb hinter Reverse Proxy
FORCE_HTTPS=true
REQUIRE_MOBILE=false

# Login-Brute-Force-Schutz
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=8
LOGIN_RATE_BLOCK_MS=900000

# Externe API-Aufrufe, z.B. Geocoding/Favicon
EXTERNAL_FETCH_TIMEOUT_MS=5000

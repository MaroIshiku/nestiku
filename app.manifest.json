{
  "app_id": "nestiku",
  "app_name": "Nestiku",
  "app_subtitle": "Personal Startpage",
  "app_symbol": "home",
  "primary_purpose": "Nestiku ist eine private, self-hosted Startseite mit Suche, Wetter, Schnellzugriffen und geschuetztem Adminbereich.",
  "main_sections": ["start"],
  "app_logo": {
    "src": "/assets/logos/nestiku.png",
    "favicon": "/assets/logos/nestiku.png",
    "alt": "",
    "use_as_header_symbol": true,
    "use_as_favicon": true,
    "use_as_about_symbol": true,
    "use_as_profile_sheet_symbol": true,
    "use_as_empty_state_symbol": true
  },
  "first_run_setup": {
    "enabled": true,
    "route": "/setup",
    "require_setup_secret": true,
    "setup_secret_file_env": "ISHIKU_SETUP_SECRET_FILE",
    "setup_secret_env": "ISHIKU_SETUP_SECRET",
    "setup_secret_file_default": "/run/secrets/ishiku_setup_secret",
    "public_registration_after_first_admin": false,
    "admin_password_must_differ_from_setup_secret": true,
    "minimum_admin_password_length": 12
  },
  "readme_profile": {
    "repository_name": "nestiku",
    "github_owner": "MaroIshiku",
    "public_repository": true,
    "short_description": "Private Personal Startpage im gemeinsamen Pixel Soft Utility Designsystem.",
    "license": "Nicht angegeben",
    "codex_notice_enabled": true
  },
  "default_theme": "lavender",
  "default_mode": "system",
  "has_account": true,
  "user_identity_fields": ["initials", "display_name", "username"],
  "navigation_complexity": "single_view",
  "technical_info": {
    "allowed_locations": ["About", "Admin Info", "Diagnostics"]
  }
}

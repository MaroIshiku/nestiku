# Pflicht: langes Geheimnis fuer signierte HttpOnly-Session-Cookies.
# Beispiel: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-session-secret

# Optional
TZ=Europe/Berlin
ISHIKU_LOG_LEVEL=info

# First-Run Setup:
# Lege das Setup-Secret als Datei an:
#   mkdir -p secrets
#   openssl rand -base64 48 > secrets/setup_secret.txt

# Docker Compose published Port 8503 auf den internen Container-Port 8080.
